{
    "swagger": "2.0",
    "info": {
        "description": "A Lord of the Rings-themed URL shortener. Authenticated routes require an API key passed as a Bearer token in the Authorization header.",
        "title": "Lembas Links API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/links": {
            "post": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Selects an available LOTR-themed slug from the quote pool and maps it to the provided URL. The link expires after the configured TTL (default 30 days).",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "links"
                ],
                "summary": "Create a shortened link",
                "parameters": [
                    {
                        "description": "URL to shorten",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.CreateLinkRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/handlers.CreateLinkResponse"
                        }
                    },
                    "400": {
                        "description": "missing or invalid request body",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "internal error (slug pool exhausted, DB failure)",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/links/{slug}": {
            "delete": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Soft-deletes the link (sets is_active = false) and evicts it from the Redis cache. The slug is not returned to the pool.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "links"
                ],
                "summary": "Delete a shortened link",
                "parameters": [
                    {
                        "type": "string",
                        "example": "\"one-ring-to-rule\"",
                        "description": "URL slug",
                        "name": "slug",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "404": {
                        "description": "slug not found",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/links/{slug}/stats": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Returns metadata (click count, expiry, active status) and the 10 most recent click events for the given slug.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "links"
                ],
                "summary": "Get link statistics",
                "parameters": [
                    {
                        "type": "string",
                        "example": "\"one-ring-to-rule\"",
                        "description": "URL slug",
                        "name": "slug",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handlers.StatsResponse"
                        }
                    },
                    "404": {
                        "description": "slug not found or expired",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/{slug}": {
            "get": {
                "description": "Resolves a slug to its original URL (Redis cache first, then DB) and issues a 302 redirect. Click metadata is recorded asynchronously. Returns 410 if the link has expired.",
                "tags": [
                    "redirect"
                ],
                "summary": "Redirect to original URL",
                "parameters": [
                    {
                        "type": "string",
                        "example": "\"one-ring-to-rule\"",
                        "description": "URL slug",
                        "name": "slug",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Location header set to the original URL",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "slug not found or inactive",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "410": {
                        "description": "link has expired",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handlers.ClickResponse": {
            "type": "object",
            "properties": {
                "clicked_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "ip_address": {
                    "type": "string",
                    "example": "127.0.0.1"
                },
                "referrer": {
                    "type": "string",
                    "example": "https://google.com"
                },
                "slug": {
                    "type": "string",
                    "example": "one-ring-to-rule"
                },
                "user_agent": {
                    "type": "string",
                    "example": "Mozilla/5.0"
                }
            }
        },
        "handlers.CreateLinkRequest": {
            "type": "object",
            "properties": {
                "api_key": {
                    "type": "string",
                    "example": "my-api-key"
                },
                "url": {
                    "type": "string",
                    "example": "https://example.com/some/very/long/path"
                }
            }
        },
        "handlers.CreateLinkResponse": {
            "type": "object",
            "properties": {
                "original": {
                    "type": "string",
                    "example": "https://example.com/some/very/long/path"
                },
                "short_url": {
                    "type": "string",
                    "example": "http://localhost:8080/one-ring-to-rule"
                },
                "slug": {
                    "type": "string",
                    "example": "one-ring-to-rule"
                }
            }
        },
        "handlers.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "slug not found"
                }
            }
        },
        "handlers.StatsResponse": {
            "type": "object",
            "properties": {
                "click_count": {
                    "type": "integer",
                    "example": 42
                },
                "created_at": {
                    "type": "string"
                },
                "expires_at": {
                    "type": "string"
                },
                "is_active": {
                    "type": "boolean",
                    "example": true
                },
                "original": {
                    "type": "string",
                    "example": "https://example.com"
                },
                "recent_clicks": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/handlers.ClickResponse"
                    }
                },
                "slug": {
                    "type": "string",
                    "example": "one-ring-to-rule"
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "description": "API key prefixed with \"Bearer \" (e.g. \"Bearer my-api-key\")",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}